rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Required for the authenticated administrator's cross-date export,
    // batch deletion and "clear all" collection-group reads.
    match /{path=**}/appointments/{appointmentId} {
      allow read: if request.auth != null;
    }

    match /salons/default/dates/{date}/appointments/{appointmentId} {
      allow read, write: if request.auth != null;
    }

    match /salons/default/trash/{trashId} {
      allow read, write: if request.auth != null;
    }

    match /salons/default/auditLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /salons/default/services/{serviceId} {
      allow read, write: if request.auth != null;
    }
  }
}
